# 本地开发：npm run dev:api 时可选兜底 Key（生产 BYOK，勿提交真实 Key）
# ARK_API_KEY=
# ARK_MODEL=doubao-seed-2-1-pro-260628
# 也可填控制台接入点 ID：ep-xxxxxxxx
# 文档：https://console.volcengine.com/ark/region:cn-beijing/docs/82379/1399008?lang=zh
# ARK_ENDPOINT=https://ark.cn-beijing.volces.com/api/v3/chat/completions
# CAPTION_GEN_PORT=8791
# ALLOWED_ORIGIN=*

# 前端（可选，默认走同源 /api/caption-gen）
# VITE_CAPTION_API_URL=http://127.0.0.1:8791/api/caption-gen
